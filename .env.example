# Environment Variables Configuration
# Copy this file to .env.local and fill in your actual values

# =====================================================
# SUPABASE CONFIGURATION
# =====================================================

# Supabase Project URL
# Get from: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# Supabase Anonymous Key (Client-side safe)
# Get from: https://supabase.com/dashboard -> Settings -> API
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Service Role Key (Server-side only!)
# Get from: https://supabase.com/dashboard -> Settings -> API
# WARNING: Keep this SECRET, never expose to client
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# =====================================================
# GOOGLE AI CONFIGURATION
# =====================================================

# Google Gemini API Key for AI features
# Get from: https://ai.google.dev/
# Used for: Recommendations, content generation, analysis
GEMINI_API_KEY=your_gemini_api_key_here

# Optional model overrides (defaults shown)
# GEMINI_TEXT_MODEL=gemini-2.0-flash
# GEMINI_EMBED_MODEL=text-embedding-004

# =====================================================
# GOOGLE CLOUD (GCS + Translation)
# =====================================================

# GCS bucket for avatars, blog, showcase, launch gallery
GCS_BUCKET_NAME=aikesif-media

# Attempt per-object public ACL after upload (default: true).
# Disable if the bucket uses uniform bucket-level public access only.
# GCS_MAKE_PUBLIC=true

# Local dev: path to service account JSON file (gitignored as google-credentials.json)
# GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json

# Vercel / production: paste full service-account JSON as a single-line string
# (or base64-encoded JSON). Prefer this over key files on serverless.
# GCP_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
GCP_SERVICE_ACCOUNT_JSON=
# Backward-compatible alias also supported if already configured in Vercel:
# GOOGLE_CREDENTIALS_JSON=

# =====================================================
# VERCEL CONFIGURATION
# =====================================================

# Vercel Analytics ID for tracking
# Get from: Vercel Dashboard -> Analytics
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your_vercel_analytics_id

# =====================================================
# EMAIL CONFIGURATION (Resend)
# =====================================================

# Resend API Key for sending emails
# Get from: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here

# Email address for admin notifications
# Used for: System alerts, important notifications
ADMIN_NOTIF_EMAIL_FROM=noreply@yourdomain.com

# =====================================================
# PAYMENT CONFIGURATION (Stripe)
# =====================================================

# Stripe Public Key (Client-side safe)
# Get from: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=your_stripe_public_key

# Stripe Secret Key (Server-side only!)
# Get from: https://dashboard.stripe.com/apikeys
# WARNING: Keep this SECRET, never expose to client
STRIPE_SECRET_KEY=your_stripe_secret_key

# Optional server-side promo codes for Stripe checkout.
# Keep real invite codes out of the repository.
# Example:
# PROMO_CODES_JSON={"INVITE-CODE":{"label":"Davet Kodu","percentOff":50,"duration":"once","active":true}}
PROMO_CODES_JSON={}

# =====================================================
# ADMIN CONFIGURATION
# =====================================================

# Admin email for dashboard access
# This email will have full admin privileges
ADMIN_EMAIL=admin@example.com

# Secret for cron job authorization (generate a strong random string)
CRON_SECRET=your_cron_secret_here

# Automated tool discovery cron
# Defaults are conservative. Auto-approve is OFF unless explicitly enabled.
TOOL_DISCOVERY_LIMIT=8
TOOL_DISCOVERY_CANDIDATE_COUNT=18
TOOL_DISCOVERY_TIMEOUT_MS=7000
TOOL_DISCOVERY_AUTO_APPROVE=false
# Optional for local/remote manual trigger script:
# TOOL_DISCOVERY_URL=http://localhost:3005/api/cron/tool-discovery

# =====================================================
# GROK API CONFIGURATION (xAI) - ŞU ANDA KULLANILIYOR
# =====================================================

# Grok API Key (xAI)
# Get from: https://console.x.ai
XAI_API_KEY=your_xai_api_key

# =====================================================
# OPTIONAL: DEVELOPMENT CONFIGURATION
# =====================================================

# Enable debug mode for development
DEBUG=false

# Database connection timeout (ms)
DB_TIMEOUT=5000

# API rate limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=60

# =====================================================
# OPTIONAL: THIRD-PARTY SERVICES
# =====================================================

# Sentry for error tracking (optional)
# NEXT_PUBLIC_SENTRY_DSN=https://xxxx@sentry.io/project-id
# SENTRY_DSN=https://xxxx@sentry.io/project-id
# SENTRY_AUTH_TOKEN=your_sentry_auth_token_here

# LogRocket for session replay (optional)
# LOGROCKET_PROJECT_ID=your_logrocket_id_here

# =====================================================
# NOTES
# =====================================================

# 1. NEXT_PUBLIC_* variables are exposed to browser
#    Only put non-sensitive data in these
#
# 2. Non-prefixed variables are server-only
#    Use these for sensitive keys like API secrets
#
# 3. Copy this file to .env.local:
#    cp .env.example .env.local
#
# 4. Never commit .env.local to version control
#    It's listed in .gitignore
#
# 5. For production, set these in your hosting platform
#    (Vercel Dashboard, environment variables section)
#
# 6. More info: https://nextjs.org/docs/basic-features/environment-variables
