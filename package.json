{
  "name": "ai-kesif-platformu",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3005 --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "verify": "npm run lint && npm run build",
    "tools:audit-links": "node ./scripts/tool-link-audit.mjs",
    "tools:audit-links:dry-run": "node ./scripts/tool-link-audit.mjs --dry-run",
    "tools:audit-links:deactivate": "node ./scripts/tool-link-audit.mjs --deactivate --confirm=DEACTIVATE_INVALID_TOOLS",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "format": "prettier --write .",
    "analyze": "cross-env ANALYZE=true next build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
